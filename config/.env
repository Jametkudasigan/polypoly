# ==========================================
# Polymarket BTC Bot Configuration
# ==========================================

# Wallet Configuration
# Export dari Polymarket Settings (Private Key)
POLYMARKET_PRIVATE_KEY=0x...

# Proxy Wallet Address (tempat deposit USDC)
POLYMARKET_FUNDER_ADDRESS=0x...

# Signature Type: 1 = Email/Magic, 2 = MetaMask Proxy
SIGNATURE_TYPE=1

# ==========================================
# Trading Parameters
# ==========================================
POSITION_SIZE=1.0
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
PRICE_MIN=0.45
PRICE_MAX=0.55

# Time Filters (minutes)
MIN_TIME_REMAINING=2
MAX_TIME_REMAINING=10

# ==========================================
# API Configuration (Optional)
# ==========================================
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
DATA_HOST=https://data-api.polymarket.com
CHAIN_ID=137

# Builder API untuk Gasless Trading (Optional)
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=
