# Wallet Configuration
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_proxy_wallet_address
SIGNATURE_TYPE=1  # 1 untuk Email/Magic, 2 untuk MetaMask Proxy

# Trading Parameters
POSITION_SIZE=1.0
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
PRICE_MIN=0.45
PRICE_MAX=0.55

# Time Filters (minutes)
MIN_TIME_REMAINING=2
MAX_TIME_REMAINING=10

# API Configuration
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
DATA_HOST=https://data-api.polymarket.com
CHAIN_ID=137

# Optional: Builder API (untuk relayer gasless)
BUILDER_API_KEY=optional
BUILDER_SECRET=optional
BUILDER_PASSPHRASE=optional
